<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    android:background="@color/white"
    android:gravity="center_vertical"
    android:minHeight="82dp"
    android:orientation="horizontal"
    android:paddingStart="18dp"
    android:paddingTop="16dp"
    android:paddingEnd="18dp"
    android:paddingBottom="16dp">

    <CheckBox
        android:id="@+id/combo_candidate_check_box"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:buttonTint="@color/primary_green"
        android:paddingEnd="12dp"
        android:textColor="@color/primary_text"
        android:textSize="16sp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/combo_candidate_minus_button"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:minWidth="0dp"
        android:text=""
        app:backgroundTint="@color/white"
        app:cornerRadius="22dp"
        app:icon="@drawable/ic_minus"
        app:iconSize="18dp"
        app:iconTint="@color/secondary_text"
        app:strokeColor="@color/top_nav_active_stroke"
        app:strokeWidth="1dp" />

    <TextView
        android:id="@+id/combo_candidate_quantity_text"
        android:layout_width="48dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="0"
        android:textColor="@color/primary_text"
        android:textSize="18sp"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/combo_candidate_plus_button"
        style="@style/Widget.Material3.Button.OutlinedButton"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:minWidth="0dp"
        android:text=""
        app:backgroundTint="@color/white"
        app:cornerRadius="22dp"
        app:icon="@drawable/ic_add"
        app:iconSize="18dp"
        app:iconTint="@color/secondary_text"
        app:strokeColor="@color/divider_color"
        app:strokeWidth="1dp" />
</LinearLayout>
