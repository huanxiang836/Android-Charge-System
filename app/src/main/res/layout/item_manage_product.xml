<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="@color/panel_background"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/divider_color"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="18dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/manage_product_name_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary_text"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/manage_product_meta_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/secondary_text"
                android:textSize="14sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/manage_product_status_text"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@color/category_badge_background"
            android:gravity="center"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:textColor="@color/secondary_text"
            android:textSize="13sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/manage_product_edit_button"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="92dp"
            android:layout_height="42dp"
            android:layout_marginStart="12dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="@string/manage_combo_edit"
            android:textSize="14sp"
            android:visibility="gone"
            app:cornerRadius="14dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/manage_product_action_button"
            style="@style/Widget.Material3.Button"
            android:layout_width="92dp"
            android:layout_height="42dp"
            android:layout_marginStart="14dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:textSize="14sp"
            app:cornerRadius="14dp" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
