<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="620dp"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/spec_product_name_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/primary_text"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/spec_product_price_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:textColor="@color/price_highlight"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/spec_combo_summary_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:textColor="@color/secondary_text"
            android:textSize="14sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/spec_size_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@color/spec_group_background"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary_text"
                android:textSize="16sp"
                android:textStyle="bold"
                android:text="@string/spec_size_title" />

            <RadioGroup
                android:id="@+id/size_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/size_medium_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/primary_green"
                    android:checked="true"
                    android:text="@string/spec_size_medium"
                    android:textColor="@color/primary_text"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/size_large_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="28dp"
                    android:buttonTint="@color/primary_green"
                    android:text="@string/spec_size_large"
                    android:textColor="@color/primary_text"
                    android:textSize="15sp" />
            </RadioGroup>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/spec_temperature_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@color/spec_group_background"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/primary_text"
                android:textSize="16sp"
                android:textStyle="bold"
                android:text="@string/spec_temperature_title" />

            <RadioGroup
                android:id="@+id/temperature_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/temperature_iced_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/primary_green"
                    android:checked="true"
                    android:text="@string/spec_temperature_iced"
                    android:textColor="@color/primary_text"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/temperature_normal_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="28dp"
                    android:buttonTint="@color/primary_green"
                    android:text="@string/spec_temperature_normal"
                    android:textColor="@color/primary_text"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/temperature_hot_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="28dp"
                    android:buttonTint="@color/primary_green"
                    android:text="@string/spec_temperature_hot"
                    android:textColor="@color/primary_text"
                    android:textSize="15sp" />
            </RadioGroup>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/spec_sweetness_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@color/spec_group_background"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/spec_sweetness_title"
                android:textColor="@color/primary_text"
                android:textSize="16sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/sweetness_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <RadioButton
                    android:id="@+id/sweetness_regular_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/primary_green"
                    android:checked="true"
                    android:text="@string/spec_sweetness_regular"
                    android:textColor="@color/primary_text"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/sweetness_less_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="28dp"
                    android:buttonTint="@color/primary_green"
                    android:text="@string/spec_sweetness_less"
                    android:textColor="@color/primary_text"
                    android:textSize="15sp" />

                <RadioButton
                    android:id="@+id/sweetness_light_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="28dp"
                    android:buttonTint="@color/primary_green"
                    android:text="@string/spec_sweetness_light"
                    android:textColor="@color/primary_text"
                    android:textSize="15sp" />
            </RadioGroup>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="end"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/spec_cancel_button"
                style="@style/Widget.Material3.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@android:string/cancel"
                android:textColor="@color/secondary_text" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/spec_confirm_button"
                style="@style/Widget.Material3.Button"
                android:layout_width="wrap_content"
                android:layout_height="52dp"
                android:layout_marginStart="12dp"
                android:text="@string/spec_confirm"
                android:textSize="17sp"
                app:backgroundTint="@color/primary_green"
                app:cornerRadius="14dp" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
